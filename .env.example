# Core runtime
# Use the pooled connection for normal app traffic.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/virtura_presence?sslmode=require"
# Use the direct, non-pooled connection for Prisma migrations and other direct operations.
DATABASE_URL_UNPOOLED="postgresql://USER:PASSWORD@HOST:5432/virtura_presence?sslmode=require"

# Vercel + Neon compatibility variables
# These are commonly injected by the Vercel Postgres / Neon integration.
PGHOST=""
PGHOST_UNPOOLED=""
PGUSER=""
PGDATABASE=""
PGPASSWORD=""
POSTGRES_URL=""
POSTGRES_URL_NON_POOLING=""
POSTGRES_USER=""
POSTGRES_HOST=""
POSTGRES_PASSWORD=""
POSTGRES_DATABASE=""
POSTGRES_URL_NO_SSL=""
POSTGRES_PRISMA_URL=""

APP_BASE_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-a-long-random-secret"
ADMIN_EMAIL="admin@virturagroup.com"
ADMIN_NAME="Virtura Admin"
ADMIN_PASSWORD="replace-real-admin-password"

# Feature flags and operational toggles
ENABLE_DEMO_AUTH="false"
SEED_DEMO_DATA="false"
EMAIL_DELIVERY_MODE="auto"
NOTIFICATION_BATCH_LIMIT="25"

# Transactional email
RESEND_API_KEY=""
RESEND_FROM_EMAIL="hello@mail.virtura.us"
RESEND_FROM_NAME="Virtura Presence"
RESEND_REPLY_TO="support@virtura.us"

# Optional demo credentials
DEMO_CONSULTANT_EMAIL="consultant@virturagroup.com"
DEMO_CONSULTANT_PASSWORD="replace-demo-consultant-password"
DEMO_CLIENT_EMAIL="client@virturapresence.com"
DEMO_CLIENT_PASSWORD="replace-demo-client-password"
