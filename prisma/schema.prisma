generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

enum UserRole {
  CLIENT
  CONSULTANT
  ADMIN
}

enum SubmissionStatus {
  SUBMITTED
  AWAITING_REVIEW
  IN_REVIEW
  PUBLISHED
  FOLLOW_UP_SENT
  CONVERTED
  CLOSED
}

enum ScoreTier {
  STRONG_FOOTING
  PROMISING_UPSIDE
  FOCUSED_ATTENTION
}

enum AuditStatus {
  DRAFT
  INTERNAL_REVIEW
  READY_TO_PUBLISH
  PUBLISHED
}

enum AuditCategory {
  WEBSITE_PRESENCE
  GOOGLE_LOCAL_PRESENCE
  REVIEWS_TRUST
  SOCIAL_BRAND_ACTIVITY
  CUSTOMER_ACTION_READINESS
}

enum RecommendationStatus {
  PROPOSED
  PRESENTED
  ACCEPTED
  DECLINED
}

enum FollowUpStatus {
  QUEUED
  SCHEDULED
  SENT
  REPLIED
  BOOKED
  CLOSED
}

enum AdvertisingCadence {
  YES
  OCCASIONALLY
  NO
}

enum ReviewCollectionLevel {
  YES
  SOMEWHAT
  NOT_YET
}

enum NotificationEventType {
  SUBMISSION_CREATED
  CLAIM_LINK_CREATED
  ACCOUNT_LINKED
  EMAIL_VERIFICATION_READY
  AUDIT_SAVED
  AUDIT_PUBLISHED
  FOLLOW_UP_QUEUED
  FOLLOW_UP_SENT
  SERVICE_RECOMMENDED
}

enum NotificationStatus {
  PENDING
  LOGGED
  PROCESSED
  FAILED
}

enum UserActionTokenType {
  CLAIM_SUBMISSION
  VERIFY_EMAIL
}

model User {
  id                      String              @id @default(cuid())
  name                    String?
  email                   String              @unique
  emailVerified           DateTime?
  image                   String?
  phone                   String?
  companyName             String?
  timezone                String?             @default("America/Chicago")
  passwordHash            String?
  role                    UserRole            @default(CLIENT)
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt
  accounts                Account[]
  sessions                Session[]
  ownedBusinesses         Business[]          @relation("BusinessPrimaryContact")
  assignedBusinesses      Business[]          @relation("BusinessAssignedConsultant")
  submittedPresenceChecks PresenceCheck[]     @relation("PresenceCheckSubmitter")
  assignedSubmissions     PresenceCheck[]     @relation("PresenceCheckAssignedConsultant")
  authoredAudits          ManualAudit[]       @relation("ManualAuditAuthor")
  publishedAudits         ManualAudit[]       @relation("ManualAuditPublisher")
  authoredInternalNotes   InternalNote[]      @relation("InternalNoteAuthor")
  actionTokens            UserActionToken[]   @relation("UserActionTokenUser")
  notificationEvents      NotificationEvent[] @relation("NotificationEventUser")
}

model Business {
  id                       String               @id @default(cuid())
  name                     String
  slug                     String               @unique
  ownerName                String?
  businessCategory         String
  city                     String
  state                    String
  serviceArea              String?
  primaryEmail             String
  primaryPhone             String?
  websiteUrl               String?
  googleBusinessProfileUrl String?
  socialProfiles           Json?
  discoveryChannels        Json?
  goals                    Json?
  notes                    String?
  leadSource               String               @default("presence-check")
  status                   SubmissionStatus     @default(SUBMITTED)
  quickScore               Int?
  quickTier                ScoreTier?
  quickSummary             String?
  primaryContactId         String?
  assignedConsultantId     String?
  submittedAt              DateTime             @default(now())
  latestSubmittedAt        DateTime?
  publishedAt              DateTime?
  createdAt                DateTime             @default(now())
  updatedAt                DateTime             @updatedAt
  primaryContact           User?                @relation("BusinessPrimaryContact", fields: [primaryContactId], references: [id], onDelete: SetNull)
  assignedConsultant       User?                @relation("BusinessAssignedConsultant", fields: [assignedConsultantId], references: [id], onDelete: SetNull)
  presenceChecks           PresenceCheck[]
  audits                   ManualAudit[]
  planRecommendations      PlanRecommendation[]
  internalNotes            InternalNote[]
  followUps                FollowUp[]
  notificationEvents       NotificationEvent[]
}

model PresenceCheck {
  id                       String                @id @default(cuid())
  businessId               String
  submittedById            String?
  assignedConsultantId     String?
  status                   SubmissionStatus      @default(SUBMITTED)
  businessName             String
  ownerName                String
  contactEmail             String
  contactPhone             String?
  businessCategory         String
  city                     String
  state                    String
  serviceArea              String
  hasWebsite               Boolean?
  websiteUrl               String?
  usesGoogleBusinessProfile Boolean?
  googleBusinessProfileUrl String?
  socialPlatforms          Json?
  runsAdvertising          AdvertisingCadence    @default(NO)
  discoveryChannels        Json?
  collectsReviews          ReviewCollectionLevel @default(SOMEWHAT)
  desiredOutcomes          Json?
  rawNotes                 String?
  score                    Int?
  scoreTier                ScoreTier?
  summary                  String?
  encouragement            String?
  strengths                Json?
  improvementAreas         Json?
  submittedAt              DateTime              @default(now())
  updatedAt                DateTime              @updatedAt
  business                 Business              @relation(fields: [businessId], references: [id], onDelete: Cascade)
  submittedBy              User?                 @relation("PresenceCheckSubmitter", fields: [submittedById], references: [id], onDelete: SetNull)
  assignedConsultant       User?                 @relation("PresenceCheckAssignedConsultant", fields: [assignedConsultantId], references: [id], onDelete: SetNull)
  categoryScores           PresenceCheckCategory[]
  audit                    ManualAudit?
  planRecommendations      PlanRecommendation[]
  internalNotes            InternalNote[]
  followUps                FollowUp[]
  actionTokens             UserActionToken[]
  notificationEvents       NotificationEvent[]

  @@index([status, scoreTier, submittedAt(sort: Desc)])
  @@index([contactEmail])
  @@index([businessCategory, state])
}

model PresenceCheckCategory {
  id              String        @id @default(cuid())
  presenceCheckId String
  category        AuditCategory
  score           Int
  note            String
  displayOrder    Int           @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  presenceCheck   PresenceCheck @relation(fields: [presenceCheckId], references: [id], onDelete: Cascade)

  @@unique([presenceCheckId, category])
}

model ManualAudit {
  id                       String               @id @default(cuid())
  businessId               String
  presenceCheckId          String               @unique
  authorId                 String?
  publishedById            String?
  status                   AuditStatus          @default(DRAFT)
  title                    String               @default("Manual Presence Audit")
  executiveSummary         String?
  clientSummary            String?
  internalSummary          String?
  strengths                String[]             @default([])
  improvementOpportunities String[]             @default([])
  nextSteps                String[]             @default([])
  publishedAt              DateTime?
  createdAt                DateTime             @default(now())
  updatedAt                DateTime             @updatedAt
  business                 Business             @relation(fields: [businessId], references: [id], onDelete: Cascade)
  submission               PresenceCheck        @relation(fields: [presenceCheckId], references: [id], onDelete: Cascade)
  author                   User?                @relation("ManualAuditAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  publishedBy              User?                @relation("ManualAuditPublisher", fields: [publishedById], references: [id], onDelete: SetNull)
  sections                 AuditSection[]
  planRecommendations      PlanRecommendation[]
  notificationEvents       NotificationEvent[]
}

model AuditSection {
  id                String        @id @default(cuid())
  auditId           String
  category          AuditCategory
  score             Int?
  headline          String
  clientFacingNotes String
  internalNotes     String?
  displayOrder      Int           @default(0)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  audit             ManualAudit   @relation(fields: [auditId], references: [id], onDelete: Cascade)

  @@unique([auditId, category])
}

model ServicePlan {
  id                  String               @id @default(cuid())
  slug                String               @unique
  name                String
  tagline             String
  summary             String
  idealFor            String
  tierLabel           String
  featured            Boolean              @default(false)
  accentColor         String?
  deliverables        Json
  outcomes            Json
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  planRecommendations PlanRecommendation[]
}

model PlanRecommendation {
  id             String               @id @default(cuid())
  businessId     String
  presenceCheckId String?
  auditId        String?
  servicePlanId  String
  rationale      String
  priority       Int                  @default(2)
  status         RecommendationStatus @default(PROPOSED)
  clientVisible  Boolean              @default(true)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  business       Business             @relation(fields: [businessId], references: [id], onDelete: Cascade)
  submission     PresenceCheck?       @relation(fields: [presenceCheckId], references: [id], onDelete: Cascade)
  audit          ManualAudit?         @relation(fields: [auditId], references: [id], onDelete: SetNull)
  servicePlan    ServicePlan          @relation(fields: [servicePlanId], references: [id], onDelete: Restrict)

  @@index([presenceCheckId])
}

model InternalNote {
  id             String        @id @default(cuid())
  businessId     String
  presenceCheckId String?
  authorId       String?
  title          String?
  body           String
  pinned         Boolean       @default(false)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  business       Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  submission     PresenceCheck? @relation(fields: [presenceCheckId], references: [id], onDelete: Cascade)
  author         User?         @relation("InternalNoteAuthor", fields: [authorId], references: [id], onDelete: SetNull)
}

model FollowUp {
  id             String         @id @default(cuid())
  businessId     String
  presenceCheckId String?
  status         FollowUpStatus @default(QUEUED)
  channel        String         @default("email")
  subject        String?
  scheduledFor   DateTime?
  sentAt         DateTime?
  respondedAt    DateTime?
  outcome        String?
  notes          String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  business       Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  submission     PresenceCheck? @relation(fields: [presenceCheckId], references: [id], onDelete: Cascade)
}

model NotificationEvent {
  id             String                @id @default(cuid())
  type           NotificationEventType
  status         NotificationStatus    @default(PENDING)
  businessId     String?
  presenceCheckId String?
  auditId        String?
  userId         String?
  channel        String                @default("log")
  recipient      String?
  subject        String?
  providerMessageId String?
  payload        Json?
  errorMessage   String?
  createdAt      DateTime              @default(now())
  processedAt    DateTime?
  business       Business?             @relation(fields: [businessId], references: [id], onDelete: SetNull)
  submission     PresenceCheck?        @relation(fields: [presenceCheckId], references: [id], onDelete: SetNull)
  audit          ManualAudit?          @relation(fields: [auditId], references: [id], onDelete: SetNull)
  user           User?                 @relation("NotificationEventUser", fields: [userId], references: [id], onDelete: SetNull)
}

model UserActionToken {
  id             String              @id @default(cuid())
  type           UserActionTokenType
  token          String              @unique
  email          String
  userId         String?
  presenceCheckId String?
  expiresAt      DateTime
  consumedAt     DateTime?
  createdAt      DateTime            @default(now())
  user           User?               @relation("UserActionTokenUser", fields: [userId], references: [id], onDelete: SetNull)
  submission     PresenceCheck?      @relation(fields: [presenceCheckId], references: [id], onDelete: Cascade)

  @@index([email, type])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
